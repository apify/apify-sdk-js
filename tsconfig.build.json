{
    "extends": "@apify/tsconfig",
    "compilerOptions": {
        "target": "ESNext",
        "lib": [
            "ESNext",
            "DOM",
            "ES2020"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "resolveJsonModule": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "declarationMap": false,
        "sourceMap": false
    },
    "include": [
        "./src/**/*"
    ],
    "exclude": [
        "**/node_modules",
        "**/dist"
    ]
}
